<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Dr. MAS AI Assistant</title>
    <style>
        * { box-sizing: border-box; font-family: 'Malgun Gothic', sans-serif; margin: 0; padding: 0; }
        body { background-color: #f0f2f5; display: flex; justify-content: center; padding: 20px; height: 100vh; }
        
        /* 앱 컨테이너 (하단 탭 공간 확보를 위해 position 설정) */
        .app-container { width: 100%; max-width: 450px; background: white; border-radius: 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.1); overflow: hidden; display: flex; flex-direction: column; position: relative; padding-bottom: 60px; /* 하단바 높이만큼 여백 */ }
        
        .header { background: #0056b3; color: white; padding: 20px; text-align: center; font-size: 1.2rem; font-weight: bold; }
        .header span { font-size: 0.9rem; font-weight: normal; opacity: 0.8; display: block; margin-top: 5px; }

        /* 탭 화면 공통 설정 */
        .tab-content { flex: 1; display: flex; flex-direction: column; overflow-y: auto; height: 100%; }
        
        /* --- [1] 채팅 화면 스타일 --- */
        .chat-window { flex: 1; padding: 20px; background-color: #f4f7f6; display: flex; flex-direction: column; gap: 15px; overflow-y: auto; }
        .msg { max-width: 85%; padding: 12px 16px; border-radius: 15px; font-size: 0.95rem; line-height: 1.5; word-wrap: break-word; }
        .msg.user { align-self: flex-end; background: #007bff; color: white; border-bottom-right-radius: 2px; }
        .msg.ai { align-self: flex-start; background: white; color: #333; border: 1px solid #e1e4e8; border-bottom-left-radius: 2px; }
        .badge { display: inline-block; background: #ffebee; color: #c62828; padding: 4px 10px; border-radius: 12px; font-size: 0.85rem; font-weight: bold; margin: 2px 4px 2px 0; }
        .input-area { display: flex; padding: 15px; background: white; border-top: 1px solid #eee; }
        .input-area input { flex: 1; padding: 12px; border: 1px solid #ddd; border-radius: 20px; outline: none; }
        .input-area button { margin-left: 10px; padding: 10px 20px; background: #0056b3; color: white; border: none; border-radius: 20px; font-weight: bold; cursor: pointer; }
        .loading { font-size: 0.9rem; color: #888; align-self: flex-start; margin: 10px 0 10px 10px; display: none; }

        /* --- [2] 마이페이지 화면 스타일 (새로 추가) --- */
        .mypage-wrap { padding: 20px; background: #fff; }
        .profile-card { text-align: center; padding: 20px 0; border-bottom: 1px solid #eee; }
        .profile-pic { width: 80px; height: 80px; background: #e9ecef; border-radius: 50%; display: inline-block; line-height: 80px; font-size: 2rem; margin-bottom: 10px; }
        .menu-list { list-style: none; margin-top: 20px; }
        .menu-list li { padding: 15px 10px; border-bottom: 1px solid #f1f1f1; font-size: 1.05rem; cursor: pointer; color: #333; display: flex; justify-content: space-between; }
        .menu-list li:hover { background: #f8f9fa; }
        .menu-list li::after { content: '>'; color: #ccc; }

        /* --- [3] 하단 네비게이션 바 스타일 --- */
        .bottom-nav { position: absolute; bottom: 0; width: 100%; height: 60px; background: white; border-top: 1px solid #ddd; display: flex; }
        .nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #888; cursor: pointer; font-size: 0.85rem; transition: 0.2s; }
        .nav-item.active { color: #0056b3; font-weight: bold; }
        .nav-icon { font-size: 1.3rem; margin-bottom: 2px; }
    </style>
</head>
<body>

<div class="app-container">
    <div class="header">
        🩺 Dr. MAS
        <span>1인 가구를 위한 지능형 의료 비서</span>
    </div>
    
    <div id="view-chat" class="tab-content">
        <div class="chat-window" id="chat-window">
            <div class="msg ai">
                안녕하세요! Dr. MAS입니다. 😊<br>어디가 불편하신지 말씀해 주시면 든든한 동반자가 되어 드릴게요.
            </div>
        </div>
        <div class="loading" id="loading-msg">Dr. MAS가 의료 데이터를 정밀 분석 중입니다... ⏳</div>
        <div class="input-area">
            <input type="text" id="symptom" placeholder="증상을 입력하세요 (예: 머리가 아파요)" onkeypress="if(event.key === 'Enter') sendChat()">
            <button onclick="sendChat()">전송</button>
        </div>
    </div>

    <div id="view-mypage" class="tab-content" style="display: none;">
        <div class="mypage-wrap">
            <div class="profile-card">
                <div class="profile-pic">👤</div>
                <h3>김테스트 님</h3>
                <p style="color: #666; font-size: 0.9rem; margin-top: 5px;">1인 가구 케어 모드 활성화 중</p>
            </div>
            <ul class="menu-list">
                <li>나의 의료 기록 확인</li>
                <li>자주 가는 병원/약국 관리</li>
                <li>긴급 연락처 (보호자) 설정</li>
                <li>건강 알림 설정</li>
                <li>앱 설정</li>
            </ul>
        </div>
    </div>

    <div class="bottom-nav">
        <div class="nav-item active" id="nav-chat" onclick="switchTab('chat')">
            <div class="nav-icon">💬</div>상담하기
        </div>
        <div class="nav-item" id="nav-mypage" onclick="switchTab('mypage')">
            <div class="nav-icon">👤</div>마이페이지
        </div>
    </div>
</div>

<script>
    // --- 화면 전환(탭) 기능 (유지) ---
    function switchTab(tabName) {
        document.getElementById('view-chat').style.display = 'none';
        document.getElementById('view-mypage').style.display = 'none';
        document.getElementById('nav-chat').classList.remove('active');
        document.getElementById('nav-mypage').classList.remove('active');
        document.getElementById('view-' + tabName).style.display = 'flex';
        document.getElementById('nav-' + tabName).classList.add('active');
    }

    const chatWindow = document.getElementById('chat-window');
    const symptomInput = document.getElementById('symptom');
    const loadingMsg = document.getElementById('loading-msg');

    function appendMessage(sender, text, isAiResult = false) {
        const msgDiv = document.createElement('div');
        msgDiv.className = `msg ${sender}`;
        if (isAiResult) msgDiv.innerHTML = text;
        else msgDiv.innerText = text;
        chatWindow.appendChild(msgDiv);
        chatWindow.scrollTop = chatWindow.scrollHeight;
    }

    function getFastLocation() {
        return new Promise((resolve) => {
            if (!navigator.geolocation) return resolve({ lat: null, lng: null });

            navigator.geolocation.getCurrentPosition(
                (pos) => resolve({ lat: pos.coords.latitude, lng: pos.coords.longitude }),
                (err) => resolve({ lat: null, lng: null }), // 에러 시 바로 포기 (응답 속도 사수)
                { 
                    enableHighAccuracy: false, 
                    timeout: 3000,           
                    maximumAge: 600000        
                }
            );
        });
    }

    async function sendChat() {
        const symptomText = symptomInput.value.trim();
        if(!symptomText) return alert("증상을 입력해주세요!");
        
        appendMessage('user', symptomText);
        symptomInput.value = '';
        loadingMsg.style.display = 'block';

        try {
            const userLoc = await getFastLocation();

            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    userId: 1, 
                    symptomText: symptomText, 
                    userLat: userLoc.lat, 
                    userLng: userLoc.lng 
                })
            });
            
            const data = await response.json();
            loadingMsg.style.display = 'none';
            
            if(data.predictedDisease) {
                const diseases = data.predictedDisease.split(',');
                let badgesHtml = '<div style="margin-bottom:10px;">';
                diseases.forEach(d => { if(d.trim() !== "") badgesHtml += `<span class="badge">${d.trim()}</span>`; });
                badgesHtml += '</div>';

                const formattedGuide = data.guide.replace(/\n/g, '<br>');
                appendMessage('ai', badgesHtml + formattedGuide, true);
            }
        } catch (error) {
            loadingMsg.style.display = 'none';
            appendMessage('ai', "서버 통신에 실패했습니다.");
        }
    }
</script>

</body>
</html>
